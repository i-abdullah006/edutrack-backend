# MongoDB Atlas connection string (replace with your actual connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/attendance_system

# JWT secret key - used to sign login tokens (replace with any long random string)
JWT_SECRET=replace_this_with_any_long_random_secret_string_12345

# Server port
PORT=5000

# Used once to create the first admin account (only used when running setupAdmin.js)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123

# WebAuthn (fingerprint) settings
# For LOCAL TESTING, leave these as-is.
# After deploying, RP_ID must be your real domain (no protocol, no port),
# e.g. "yourschool.com", and ORIGIN must be the exact frontend URL including
# https://, e.g. "https://yourschool.com"
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
